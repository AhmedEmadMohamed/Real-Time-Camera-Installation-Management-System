{
  "openapi": "3.0.1",
  "info": {
    "title": "Real-Time Camera Installation Management System",
    "version": "1.0"
  },
  "paths": {
    "/api/Customers": {
      "get": {
        "tags": [
          "Customers"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      },
      "post": {
        "tags": [
          "Customers"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateCustomerDTO"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateCustomerDTO"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/CreateCustomerDTO"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Jobs": {
      "post": {
        "tags": [
          "Jobs"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateJobDTO"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateJobDTO"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/CreateJobDTO"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      },
      "get": {
        "tags": [
          "Jobs"
        ],
        "parameters": [
          {
            "name": "status",
            "in": "query",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Jobs/{id}": {
      "get": {
        "tags": [
          "Jobs"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Jobs/{id}/status": {
      "put": {
        "tags": [
          "Jobs"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateJobStatusDTO"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateJobStatusDTO"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateJobStatusDTO"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "CreateCustomerDTO": {
        "required": [
          "customerAddress",
          "customerName",
          "customerPhone"
        ],
        "type": "object",
        "properties": {
          "customerName": {
            "minLength": 1,
            "type": "string"
          },
          "customerPhone": {
            "minLength": 1,
            "pattern": "^(010|011|012|015)\\d{8}$",
            "type": "string"
          },
          "customerAddress": {
            "minLength": 1,
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "CreateJobDTO": {
        "required": [
          "customerId",
          "jobDescription",
          "jobTitle"
        ],
        "type": "object",
        "properties": {
          "jobTitle": {
            "minLength": 1,
            "type": "string"
          },
          "customerId": {
            "type": "integer",
            "format": "int32"
          },
          "jobDescription": {
            "minLength": 1,
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "UpdateJobStatusDTO": {
        "required": [
          "jobStatus"
        ],
        "type": "object",
        "properties": {
          "jobStatus": {
            "minLength": 1,
            "pattern": "^(Pending|In Progress|Completed|Cancelled)$",
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    }
  }
}